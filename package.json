{
  "name": "iris-go",
  "version": "1.0.0",
  "description": "IRIS GO Neural OS Headless Engine",
  "main": "dist/index.js",
  "bin": {
    "iris": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --ignore src/surface/**/* index.ts",
    "build:surface": "vite build -c iris.vite.config.ts",
    "build:kernel": "tsc -p tsconfig.node.json",
    "build": "npm run build:surface && npm run build:kernel",
    "start": "NODE_ENV=production node dist/index.js",
    "format": "prettier --write .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/201Harsh/IRIS-GO.git"
  },
  "author": "Harsh Pandey",
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
