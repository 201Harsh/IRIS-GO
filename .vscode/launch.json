{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Kernel (Node)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Launch Surface (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3042",
      "webRoot": "${workspaceFolder}/src/surface"
    }
  ],
  "compounds": [
    {
      "name": "Debug IRIS Fullstack",
      "configurations": ["Attach to Kernel (Node)", "Launch Surface (Chrome)"]
    }
  ]
}
